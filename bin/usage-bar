#!/usr/bin/env bash
# usage-bar — one-command control for the cli-usage-bar menu bar app.
set -euo pipefail

LABEL="com.svenedik.cli-usage-bar"
INSTALL_DIR="${CLI_USAGE_BAR_HOME:-$HOME/.local/share/cli-usage-bar}"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
CONFIG="$HOME/.config/cli-usage-bar/config.toml"
LOG="/tmp/cli-usage-bar.log"

info()  { printf "\033[1;34m==>\033[0m %s\n" "$*"; }
warn()  { printf "\033[1;33m!!\033[0m %s\n" "$*"; }
die()   { printf "\033[1;31mxx\033[0m %s\n" "$*" >&2; exit 1; }

ensure_plist() {
    [[ -f "$PLIST" ]] || die "LaunchAgent not installed. Run install.sh first."
}

cmd_start() {
    ensure_plist
    launchctl load "$PLIST" 2>/dev/null || true
    info "started"
}

cmd_stop() {
    [[ -f "$PLIST" ]] || { warn "LaunchAgent not installed"; return 0; }
    launchctl unload "$PLIST" 2>/dev/null || true
    info "stopped"
}

cmd_restart() {
    ensure_plist
    launchctl kickstart -k "gui/$UID/${LABEL}"
    info "restarted"
}

cmd_status() {
    if launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "$LABEL"; then
        local pid
        pid=$(launchctl list | awk -v l="$LABEL" '$3==l {print $1}')
        if [[ "$pid" == "-" ]]; then
            echo "loaded (not running)"
        else
            echo "running (pid $pid)"
        fi
    else
        echo "stopped"
    fi
}

cmd_logs() {
    [[ -f "$LOG" ]] || die "log file not found: $LOG"
    tail -n 50 -f "$LOG"
}

cmd_config() {
    [[ -f "$CONFIG" ]] || die "config not found: $CONFIG (start the app once to create defaults)"
    open "$CONFIG"
}

cmd_update() {
    [[ -d "$INSTALL_DIR/.git" ]] || die "not a git install: $INSTALL_DIR"
    info "pulling latest"
    git -C "$INSTALL_DIR" pull --ff-only
    info "syncing deps"
    (cd "$INSTALL_DIR" && uv sync --frozen --no-dev 2>/dev/null || uv sync --no-dev)
    cmd_restart
}

cmd_uninstall() {
    if [[ -f "$PLIST" ]]; then
        launchctl unload "$PLIST" 2>/dev/null || true
        rm -f "$PLIST"
    fi
    rm -rf "$INSTALL_DIR"
    rm -f "$HOME/.local/bin/usage-bar"
    info "uninstalled. config left intact at: $CONFIG"
    info "remove config manually with:  rm -rf $(dirname "$CONFIG")"
}

cmd_help() {
    cat <<USAGE
usage-bar — control the cli-usage-bar menu bar app

  usage-bar start        start the app (load LaunchAgent)
  usage-bar stop         stop the app (unload LaunchAgent)
  usage-bar restart      restart the running app (pick up code changes)
  usage-bar status       show whether the app is running
  usage-bar logs         tail -f $LOG
  usage-bar config       open $CONFIG
  usage-bar update       git pull + deps + restart
  usage-bar uninstall    remove LaunchAgent and install dir
  usage-bar help         this message

env:
  CLI_USAGE_BAR_HOME     install dir (default: $HOME/.local/share/cli-usage-bar)
USAGE
}

case "${1:-help}" in
    start)                 cmd_start ;;
    stop)                  cmd_stop ;;
    restart|kick|reload)   cmd_restart ;;
    status|st)             cmd_status ;;
    logs|log|tail)         cmd_logs ;;
    config|cfg|edit)       cmd_config ;;
    update|upgrade|pull)   cmd_update ;;
    uninstall|remove)      cmd_uninstall ;;
    -h|--help|help|"")     cmd_help ;;
    *) die "unknown command: $1  (try: usage-bar help)" ;;
esac
